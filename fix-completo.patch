@@ -37,10 +37,13 @@ queryClient.getMutationCache().subscribe(event => {
   }
 });
 
+const apiBase = import.meta.env.VITE_API_URL ?? "";
+const trpcUrl = apiBase ? `${apiBase}/api/trpc` : "/api/trpc";
+
 const trpcClient = trpc.createClient({
   links: [
     httpBatchLink({
-      url: "/api/trpc",
+      url: trpcUrl,
       transformer: superjson,
       fetch(input, init) {
         return globalThis.fetch(input, {
diff --git a/drizzle/fix_email_nullable.sql b/drizzle/fix_email_nullable.sql
new file mode 100644
index 0000000..c7f7b51
--- /dev/null
+++ b/drizzle/fix_email_nullable.sql
@@ -0,0 +1,4 @@
+-- Corrige o campo email na tabela schedules para aceitar NULL
+-- Execute isso no seu banco MySQL/PlanetScale/Railway MySQL
+
+ALTER TABLE schedules MODIFY COLUMN email varchar(320) NULL;
diff --git a/drizzle/schema.ts b/drizzle/schema.ts
index 97d636b..0ddc505 100644
--- a/drizzle/schema.ts
+++ b/drizzle/schema.ts
@@ -28,7 +28,7 @@ export type InsertUser = typeof users.$inferInsert;
 export const schedules = mysqlTable("schedules", {
   id: int("id").autoincrement().primaryKey(),
   name: varchar("name", { length: 255 }).notNull(),
-  email: varchar("email", { length: 320 }).notNull(),
+  email: varchar("email", { length: 320 }),
   phone: varchar("phone", { length: 20 }),
   device: varchar("device", { length: 255 }).notNull(),
   problem: text("problem").notNull(),
diff --git a/railway.toml b/railway.toml
new file mode 100644
index 0000000..9abf5ef
--- /dev/null
+++ b/railway.toml
@@ -0,0 +1,8 @@
+[build]
+builder = "nixpacks"
+buildCommand = "pnpm install && pnpm run build"
+
+[deploy]
+startCommand = "pnpm run start"
+restartPolicyType = "on_failure"
+restartPolicyMaxRetries = 3
